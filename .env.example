PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
LOG_FILE_PATH=logs/proxy.log

PROXY_API_KEY=change-this-proxy-key

UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=change-this-upstream-key
UPSTREAM_ORGANIZATION=
UPSTREAM_PROJECT=

UPSTREAM_EXTRA_HEADERS={}

CORS_ORIGIN=
CORS_CREDENTIALS=false

BODY_LIMIT_BYTES=10485760
HEADERS_TIMEOUT_MS=300000
BODY_TIMEOUT_MS=0

STREAMING_ENABLED=true

# Retries only these exact transient responses:
# [An error occurred. Reference: ... at 2026-07-14T07:59:40.306Z]
# {"error":{"message":"The upstream provider is currently unavailable","type":"authentication_error"}}
# Set MAX_ATTEMPTS to 0 to retry until a non-matching model response is returned.
REFERENCE_ERROR_RETRY_ENABLED=true
REFERENCE_ERROR_RETRY_DELAY_MS=1000
REFERENCE_ERROR_RETRY_MAX_ATTEMPTS=0

REQUEST_RESPONSE_LOGGING=true
LOG_BODY_CONTENT=true
LOG_MAX_BODY_CHARS=20000
